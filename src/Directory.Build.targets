<Project>
  <PropertyGroup Condition="'$(MSBuildProjectName)' == 'Apigen.Immich.Client'">
    <TargetsForTfmSpecificBuildOutput>$(TargetsForTfmSpecificBuildOutput);IncludeModelsInPackage</TargetsForTfmSpecificBuildOutput>
  </PropertyGroup>

  <Target Name="IncludeModelsInPackage">
    <ItemGroup>
      <BuildOutputInPackage Include="$(OutputPath)Apigen.Immich.Models.dll" />
    </ItemGroup>
  </Target>
</Project>
